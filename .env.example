# ============================================
# TELEGRAM BOT
# ============================================
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# ============================================
# WEBAPP (your deployed index.html URL)
# Railway deploy karega to automatically milega
# Format: https://your-app.up.railway.app
# ============================================
WEBAPP_URL=https://your-app.up.railway.app
WEBAPP_PORT=3000

# ============================================
# WHATSAPP (Admin central number)
# Mode B forwarder — messages yahan jayenge
# Format: international without + e.g. 919876543210
# ============================================
ADMIN_WA_NUMBER=919876543210

# ============================================
# SYSTEM
# ============================================
NODE_ENV=production
LOG_LEVEL=info
BACKUP_INTERVAL_HOURS=6
MAX_BACKUPS=10
